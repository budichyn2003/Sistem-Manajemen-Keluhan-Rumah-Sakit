# AI Service Environment Variables
# Copy file ini menjadi `.env` dan isi dengan value sebenarnya

# Google Gemini API Key (required)
# Dapatkan dari: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Token (optional, required jika ingin pakai Telegram Bot)
# Dapatkan dari: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTuvWXYZabcdef

# Next.js API URL (default: http://localhost:3000)
NEXTJS_API_URL=http://localhost:3000

# FastAPI Server Configuration
# FASTAPI_HOST=0.0.0.0
# FASTAPI_PORT=8000
